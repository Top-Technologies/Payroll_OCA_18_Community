<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="report_payslip">
        <t t-call="web.html_container">
            <t t-set="first_record" t-value="docs[0]"/>
            <t t-call="web.external_layout">
                <link rel="stylesheet" href="/payroll/static/src/style.css"/>
                <div class="page">
                    <div class="header-right">
                        Date: <span t-field="first_record.date_from"/>
                        <br/>
                        Ref No:____________________
                    </div>
                    <div class="header-left bank-info">
                        To: The Bank Manager
                        <br/>
                        <span t-field="first_record.company_id.partner_id.name"/>
                        <br/>
                        <span t-field="first_record.company_id.partner_id.street"/>
                        <br/>
                        <span t-field="first_record.company_id.partner_id.city"/>, <span t-field="first_record.company_id.partner_id.state_id.name"/>
                    </div>
                    <div class="subject">
                        <b>
                            <u>Subject: Employee Salary Payment For the period
                                <span t-field="first_record.date_from"/> to <span t-field="first_record.date_to"/>
                            </u>
                        </b>
                    </div>
                    <div class="authorization-text">
                        <u>Dear Sir/Madam.</u>
                        <br/>
                        We hereby authorize the bank to debit total Amount 
                        <span t-field="first_record.company_id.currency_id.symbol"/>
                        <u>
                            <t t-set="total_amount" t-value="0"/>
                            <t t-foreach="docs" t-as="record">
                                <t t-set="net_salary" t-value="0"/>
                                <t t-foreach="record.line_ids.filtered(lambda line: line.appears_on_payslip and line.code == 'NET')" t-as="line">
                                    <t t-set="net_salary" t-value="net_salary + line.total"/>
                                </t>
                                <t t-set="total_amount" t-value="total_amount + net_salary"/>
                            </t>
                            <span t-esc="total_amount" t-options='{"widget": "monetary", "display_currency": first_record.company_id.currency_id}'/>
                        </u>
                        and credit the following list of employees with corresponding amount.
                    </div>
                    
                    <table class="table table-bordered o_table styled-table">
                        <thead>
                            <tr>
                                <th width="6%">
                                    <strong>S.N</strong>
                                </th>
                                <th width="6%">
                                    <strong>Ref.</strong>
                                </th>
                                <th>
                                    <strong>Employee</strong>
                                </th>
                                <th>
                                    <strong>Bank Account</strong>
                                </th>
                                <th>
                                    <strong>Net Salary</strong>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="count" t-value="1"/>
                            <t t-foreach="docs" t-as="record">
                                <tr>
                                    <td>
                                        <span t-esc="count"/>
                                    </td>
                                    <td>
                                        <span t-field="record.number"/>
                                    </td>
                                    <td>
                                        <span t-field="record.employee_id"/>
                                    </td>
                                    <td>
                                        <span t-field="record.employee_id.bank_account_id.acc_number"/>
                                    </td>
                                    <td>
                                        <t t-set="net_salary" t-value="0"/>
                                        <t t-foreach="record.line_ids.filtered(lambda line: line.appears_on_payslip and line.code == 'NET')" t-as="line">
                                            <t t-set="net_salary" t-value="net_salary + line.total"/>
                                        </t>
                                        <span t-esc="net_salary" t-options='{"widget": "monetary", "display_currency": record.company_id.currency_id}'/>
                                    </td>
                                </tr>
                                <t t-set="count" t-value="count + 1"/>
                            </t>
                        </tbody>
                    </table>
                    
                    <table class="table table-bordered o_table total-table" align="right">
                        <tr>
                            <td>
                                <strong>Total:</strong>
                            </td>
                            <td>
                                <t t-set="total_amount" t-value="0"/>
                                <t t-foreach="docs" t-as="record">
                                    <t t-set="net_salary" t-value="0"/>
                                    <t t-foreach="record.line_ids.filtered(lambda line: line.appears_on_payslip and line.code == 'NET')" t-as="line">
                                        <t t-set="net_salary" t-value="net_salary + line.total"/>
                                    </t>
                                    <t t-set="total_amount" t-value="total_amount + net_salary"/>
                                </t>
                                <span t-esc="total_amount" t-options='{"widget": "monetary", "display_currency": first_record.company_id.currency_id}'/>
                                <span t-field="first_record.company_id.currency_id"/>
                            </td>
                        </tr>
                    </table>
                    <br/>
                    <br/>
                    <div class="authorization-text">
                        <span>Thank you in advance on this regards.</span>
                        <br/>
                        <span>
                            <u>Best Regards,</u>
                        </span>
                    </div>
                    <table class="table o_table approve">
                        <tr>
                            <th>Prepared By:_________________</th>
                            <th>Checked By:_________________</th>
                            <th>Approved By:_________________</th>
                        </tr>
                        <br/>
                        <tr>
                            <th>Signature:_________________</th>
                            <th>Signature:_________________</th>
                            <th>Signature:_________________</th>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
